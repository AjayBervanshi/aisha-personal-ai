# ============================================================
# AISHA — Environment Variables
# ============================================================
# Copy this file: cp .env.example .env
# Fill in your actual values below
# NEVER commit your .env file to GitHub!
# ============================================================

# ── AI APIs ─────────────────────────────────────────────────

# Google Gemini (Primary AI Brain — FREE)
# Get it at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (Backup Brain — FREE)
# Get it at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Telegram ─────────────────────────────────────────────────

# Your Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID (get it from @userinfobot)
# This locks Aisha so ONLY you can use her
AJAY_TELEGRAM_ID=your_telegram_user_id_here

# ── Supabase (Memory & Database) ────────────────────────────

# Your Supabase project URL
# Find at: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (for frontend)
# Find at: Supabase Dashboard → Settings → API → anon key
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (for backend — KEEP SECRET!)
# Find at: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Optional: Voice (ElevenLabs) ─────────────────────────────

# ElevenLabs TTS (better Indian voice — has a free tier)
# Get it at: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice ID for Aisha
# Find voices at: https://elevenlabs.io/voice-library
# Recommended: "Rachel" or any Indian English voice
ELEVENLABS_VOICE_ID=your_voice_id_here

# ── App Config ───────────────────────────────────────────────

# Your name (used in prompts and logs)
USER_NAME=Ajay

# Timezone
TIMEZONE=Asia/Kolkata

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# App environment (development or production)
APP_ENV=development
