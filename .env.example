# ============================================================
# AISHA - Environment Variables
# ============================================================
# Copy this file: cp .env.example .env
# Fill in your actual values below
# NEVER commit your .env file to GitHub
# ============================================================

# AI APIs
# Google Gemini (primary)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (fallback)
GROQ_API_KEY=your_groq_api_key_here

# Lovable AI Gateway (edge function provider)
LOVABLE_API_KEY=your_lovable_api_key_here

# Optional model providers (extra fallbacks)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
XAI_API_KEY=your_xai_api_key_here

# Optional tool providers
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
AJAY_TELEGRAM_ID=your_telegram_user_id_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Python backend name
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Edge function name (Supabase functions)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Voice (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Social/content publishing (optional)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ID=your_instagram_business_id_here

# App config
USER_NAME=Ajay
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
APP_ENV=development
